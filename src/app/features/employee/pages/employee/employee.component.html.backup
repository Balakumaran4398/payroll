<div class="employee-container">
  <h1>Employee Management Page</h1>
  <p>Component loaded successfully!</p>

  <div *ngIf="loading">
    <p>Loading employees...</p>
  </div>

  <div *ngIf="!loading">
    <p>Total employees: {{ employees?.length || 0 }}</p>
    <p>Filtered employees: {{ filteredEmployees?.length || 0 }}</p>
  </div>

  <button (click)="refreshData()">Refresh Data</button>
</div>
  <div class="header-section">
    <div class="header-content">
      <h1 class="page-title">Employee Management</h1>
      <p class="page-subtitle">Manage your organization's employees and their information</p>
    </div>
    <button mat-raised-button color="primary" class="add-employee-btn" (click)="openAddEmployeeDialog()">
      <mat-icon>add</mat-icon>
      Add New Employee
    </button>
  </div>

  <!-- Search and Filters Section -->
  <mat-card class="search-card">
    <mat-card-content>
      <div class="search-section">
        <mat-form-field appearance="outline" class="search-field">
          <mat-label>Search Employees</mat-label>
          <input matInput
                 [(ngModel)]="searchTerm"
                 (input)="onSearchChange()"
                 placeholder="Search by name, email, department, position..."
                 #searchInput>
          <mat-icon matSuffix>search</mat-icon>
        </mat-form-field>

        <div class="filter-buttons">
          <button mat-stroked-button
                  [class.active]="statusFilter === 'all'"
                  (click)="setStatusFilter('all')">
            All ({{ totalEmployees }})
          </button>
          <button mat-stroked-button
                  [class.active]="statusFilter === 'active'"
                  (click)="setStatusFilter('active')">
            Active ({{ activeEmployees }})
          </button>
          <button mat-stroked-button
                  [class.active]="statusFilter === 'inactive'"
                  (click)="setStatusFilter('inactive')">
            Inactive ({{ inactiveEmployees }})
          </button>
        </div>
      </div>
    </mat-card-content>
  </mat-card>

  <!-- Loading Spinner -->
  <div *ngIf="loading" class="loading-container">
    <mat-spinner diameter="50"></mat-spinner>
    <p>Loading employees...</p>
  </div>

  <!-- Error State -->
  <div *ngIf="!loading && (!filteredEmployees || filteredEmployees.length === 0)" class="error-container">
    <mat-icon color="warn">error</mat-icon>
    <h3>{{ employees && employees.length > 0 ? 'No employees match your search' : 'Unable to load employees' }}</h3>
    <p *ngIf="employees && employees.length > 0">Try adjusting your search criteria or filters.</p>
    <p *ngIf="!employees || employees.length === 0">Please check your connection and try again.</p>
    <button mat-raised-button color="primary" (click)="employees && employees.length > 0 ? clearFilters() : refreshData()">
      <mat-icon>refresh</mat-icon>
      {{ employees && employees.length > 0 ? 'Clear Filters' : 'Retry' }}
    </button>
  </div>

  <!-- Employee Table -->
  <mat-card *ngIf="!loading && filteredEmployees && filteredEmployees.length > 0" class="table-card">
    <mat-card-header>
      <mat-card-title>Employee List</mat-card-title>
      <mat-card-subtitle>{{ filteredEmployees.length }} of {{ employees.length }} employees</mat-card-subtitle>
    </mat-card-header>

    <mat-card-content>
      <div class="table-container">
        <table mat-table [dataSource]="filteredEmployees" class="employee-table">

          <!-- Profile Column -->
          <ng-container matColumnDef="profile">
            <th mat-header-cell *matHeaderCellDef>Profile</th>
            <td mat-cell *matCellDef="let employee">
              <div class="profile-cell">
                <img [src]="employee.profile_image_url || '/assets/images/default-avatar.png'"
                     [alt]="employee.firstname + ' ' + employee.lastname"
                     class="profile-image"
                     (error)="onImageError($event)">
                <div class="profile-info">
                  <div class="employee-name">{{ employee.firstname }} {{ employee.lastname }}</div>
                  <div class="employee-id">ID: {{ employee.id }}</div>
                </div>
              </div>
            </td>
          </ng-container>

          <!-- Contact Column -->
          <ng-container matColumnDef="contact">
            <th mat-header-cell *matHeaderCellDef>Contact</th>
            <td mat-cell *matCellDef="let employee">
              <div class="contact-info">
                <div class="email">{{ employee.email }}</div>
                <div class="mobile">{{ employee.mobile }}</div>
                <div class="alternate-email" *ngIf="employee.alternate_email">{{ employee.alternate_email }}</div>
              </div>
            </td>
          </ng-container>

          <!-- Department & Position Column -->
          <ng-container matColumnDef="department">
            <th mat-header-cell *matHeaderCellDef>Department & Position</th>
            <td mat-cell *matCellDef="let employee">
              <div class="dept-position">
                <div class="department">{{ employee.department_name }}</div>
                <div class="position">{{ employee.position }}</div>
                <div class="shift-type">{{ employee.shift_type }}</div>
              </div>
            </td>
          </ng-container>

          <!-- Personal Info Column -->
          <ng-container matColumnDef="personal">
            <th mat-header-cell *matHeaderCellDef>Personal Info</th>
            <td mat-cell *matCellDef="let employee">
              <div class="personal-info">
                <div class="gender-blood">
                  <span class="gender" [class]="'gender-' + employee.gender.toLowerCase()">{{ employee.gender }}</span>
                  <span class="blood-group">{{ employee.blood_group }}</span>
                </div>
                <div class="marital-status">{{ employee.marital_status }}</div>
                <div class="dob">DOB: {{ formatDate(employee.date_of_birth) }}</div>
              </div>
            </td>
          </ng-container>

          <!-- Employment Column -->
          <ng-container matColumnDef="employment">
            <th mat-header-cell *matHeaderCellDef>Employment</th>
            <td mat-cell *matCellDef="let employee">
              <div class="employment-info">
                <div class="joining-date">Joined: {{ formatDate(employee.joining_date) }}</div>
                <div class="status" [class]="'status-' + (employee.isactive ? 'active' : 'inactive')">
                  {{ employee.isactive ? 'Active' : 'Inactive' }}
                </div>
                <div class="manager" *ngIf="employee.managerid">Manager ID: {{ employee.managerid }}</div>
              </div>
            </td>
          </ng-container>

          <!-- Actions Column -->
          <ng-container matColumnDef="actions">
            <th mat-header-cell *matHeaderCellDef>Actions</th>
            <td mat-cell *matCellDef="let employee">
              <div class="action-buttons">
                <button mat-icon-button
                        matTooltip="View Details"
                        (click)="viewEmployeeDetails(employee)">
                  <mat-icon>visibility</mat-icon>
                </button>
                <button mat-icon-button
                        matTooltip="Edit Employee"
                        (click)="editEmployee(employee)">
                  <mat-icon>edit</mat-icon>
                </button>
                <button mat-icon-button
                        matTooltip="Delete Employee"
                        (click)="deleteEmployee(employee)"
                        [disabled]="!employee.isactive">
                  <mat-icon>delete</mat-icon>
                </button>
              </div>
            </td>
          </ng-container>

          <tr mat-header-row *matHeaderRowDef="displayedColumns"></tr>
          <tr mat-row *matRowDef="let row; columns: displayedColumns;"></tr>
        </table>

        <!-- No Data Message -->
        <div *ngIf="filteredEmployees.length === 0" class="no-data">
          <mat-icon>person_off</mat-icon>
          <h3>No employees found</h3>
          <p *ngIf="searchTerm">Try adjusting your search criteria</p>
          <p *ngIf="!searchTerm">No employees match the current filters</p>
        </div>
      </div>
    </mat-card-content>
  </mat-card>
</div>


